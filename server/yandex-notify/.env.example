ALLOWED_ORIGIN=https://pehal16.github.io

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=zapiski@example.ru
SMTP_PASS=app-password
MAIL_FROM=zapiski@example.ru
MAIL_TO=zapiski@example.ru

TELEGRAM_BOT_TOKEN=0000000000:telegram-token
TELEGRAM_CHAT_ID=-1000000000000

VK_GROUP_TOKEN=vk-group-token
VK_PEER_ID=2000000001
VK_API_VERSION=5.199

# По умолчанию полные имена уходят на почту, а в TG/VK - только краткое уведомление.
# Если настоятель/ответственные подтвердят такой способ обработки данных, можно включить true.
SEND_FULL_TO_MESSENGERS=false
