ALLOWED_ORIGIN=https://pehal16.github.io,https://pehal16.github.io/hram-blagoveshcheniya-gorlovka,http://127.0.0.1:5173
DRY_RUN=false

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=zapiski@example.ru
SMTP_PASS=app-password
MAIL_FROM=zapiski@example.ru
MAIL_TO=zapiski@example.ru

TELEGRAM_BOT_TOKEN=0000000000:telegram-token
TELEGRAM_CHAT_ID=-1000000000000

VK_GROUP_TOKEN=vk-group-token
VK_PEER_ID=2000000001
VK_API_VERSION=5.199

# Для закрытой группы ответственных обычно включаем полный текст в Telegram.
SEND_FULL_TO_TELEGRAM=true
SEND_FULL_TO_VK=false

# Старый общий переключатель. Лучше использовать отдельные SEND_FULL_TO_TELEGRAM/VK.
SEND_FULL_TO_MESSENGERS=false
